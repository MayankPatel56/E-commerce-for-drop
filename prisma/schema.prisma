generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  customer  Customer?
}

/// Customers table — extends User, NO password_hash column
/// Plan Reference: §5 customers table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Customer {
  id                String     @id
  email             String     @unique
  name              String
  phone             String
  address           Json?
  role              String     @default("customer")
  isRegistered      Boolean    @default(false)
  emailConsentGiven Boolean    @default(false)
  loginAttempts     Int        @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [id], references: [id], onDelete: Cascade)
  orders            Order[]
  reviews           Review[]
  wishlist          Wishlist[]

  @@index([phone], map: "idx_customers_phone")
  @@index([role], map: "idx_customers_role")
}

/// Categories table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

/// Tags table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  productTags ProductTag[]
}

/// Products table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Product {
  id             Int              @id @default(autoincrement())
  name           String
  slug           String           @unique
  description    String?
  price          Float
  primaryImage   String?
  galleryImages  Json?
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean          @default(false)
  categoryId     Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?        @db.Timestamp(6)
  category       Category         @relation(fields: [categoryId], references: [id])
  productTags    ProductTag[]
  variants       ProductVariant[]
  reviews        Review[]
  wishlist       Wishlist[]

  @@index([categoryId], map: "idx_products_category_id")
  @@index([price], map: "idx_products_price")
}

/// Product Variants table
/// isOutOfStock maintained by DB trigger: set_is_out_of_stock
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductVariant {
  id            Int         @id @default(autoincrement())
  sku           String      @unique
  productId     Int
  variantType   String
  variantValue  String
  price         Float?
  stockQuantity Int         @default(0)
  isOutOfStock  Boolean     @default(false)
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, variantType, variantValue], map: "unique_product_variant")
  @@index([productId], map: "idx_product_variants_product_id")
  @@index([stockQuantity], map: "idx_product_variants_stock")
}

/// Product Tags junction table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductTag {
  productId Int
  tagId     Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

/// Orders table
/// shipping_address stored as JSON with state field (Resolution #8)
/// NOTE: idx_orders_pending is a partial index (WHERE status = 'pending') — not
/// expressible in Prisma schema; managed directly in PostgreSQL.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Order {
  id              Int         @id @default(autoincrement())
  orderNumber     String      @unique
  customerId      String?
  status          String      @default("pending")
  cartTotal       Float
  shippingAddress Json
  consentGiven    Boolean     @default(false)
  internalNotes   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  customer        Customer?   @relation(fields: [customerId], references: [id])
  orderItems      OrderItem[]

  @@index([customerId], map: "idx_orders_customer_id")
  @@index([status], map: "idx_orders_status")
  @@index([createdAt], map: "idx_orders_created_at")
  @@index([customerId, status], map: "idx_orders_customer_status")
}

/// Order Items table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderItem {
  id              Int            @id @default(autoincrement())
  orderId         Int
  variantId       Int
  quantity        Int
  unitPrice       Float
  variantSnapshot Json?
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId], map: "idx_order_items_order_id")
  @@index([variantId], map: "idx_order_items_variant_id")
}

/// Reviews table
/// Purchase-validated: only delivered orders can review
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Review {
  id          Int       @id @default(autoincrement())
  productId   Int
  customerId  String?
  orderId     Int?
  rating      Int
  title       String?
  comment     String?
  photoUrl    String?
  status      String    @default("pending")
  reviewedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  displayName String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([productId, customerId], map: "unique_product_customer_review")
  @@index([productId], map: "idx_reviews_product_id")
  @@index([customerId], map: "idx_reviews_customer_id")
  @@index([status], map: "idx_reviews_status")
  @@index([productId, status], map: "idx_reviews_product_status")
}

/// Wishlist table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Wishlist {
  customerId String
  productId  Int
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([customerId, productId])
}

/// FAQ table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Faq {
  id           Int      @id @default(autoincrement())
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Homepage Content table — Singleton (only 1 row)
/// Uses native JSONB columns (PostgreSQL)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model HomepageContent {
  id                 Int      @id @default(1)
  heroBanner         Json?
  featuredProductIds Json?
  categoriesSection  Json?
  whyChooseUs        Json?
  /// JSON config: {"max_reviews_to_show": N}
  customerReviews    Json
  footer             Json?
  updatedAt          DateTime @updatedAt
}

/// Settings table — Key-Value store with native JSON values
/// No email config keys (V1 sends no automated emails)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Setting {
  key   String @id
  value Json
}

/// Order Track Attempts — Database-based rate limiting
/// Cleaned up via application logic
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderTrackAttempt {
  id          Int      @id @default(autoincrement())
  ipAddress   String
  attemptTime DateTime @default(now())
  expiresAt   DateTime

  @@index([ipAddress], map: "idx_order_track_ip")
  @@index([expiresAt], map: "idx_order_track_expires")
}
