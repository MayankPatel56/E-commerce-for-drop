// Indicore Originals — Phase 1: Database & Authentication
// Supabase PostgreSQL (production target)
//
// ARCHITECTURE NOTES:
// - Provider: postgresql (Supabase managed)
// - updatedAt columns: Prisma @updatedAt (INSERT) + DB trigger (UPDATE) — dual management
// - isOutOfStock: Managed by DB trigger (set_is_out_of_stock)
// - RLS: Enabled on all 15 tables (defense-in-depth; Prisma uses service role = bypass)
// - idx_orders_pending: Partial index (WHERE status = 'pending'), managed outside Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH LAYER (equivalent to Supabase auth.users)
// Password hashes stored here — NOT in customers table (Resolution #4)
// ============================================================================

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String    // bcrypt hash — NextAuth/Credentials owns this
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt // Prisma sets on INSERT; DB trigger sets on UPDATE

  customer Customer?
}

// ============================================================================
// BUSINESS TABLES (15 tables total, including User)
// ============================================================================

/// Customers table — extends User, NO password_hash column
/// Plan Reference: §5 customers table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Customer {
  id                String     @id // References User.id — 1:1 with User
  email             String     @unique
  name              String
  phone             String     // Non-unique (Resolution: phone NOT unique constraint)
  address           Json?      // {"street","city","state","pincode"}
  role              String     @default("customer") // "admin" or "customer"
  isRegistered      Boolean    @default(false) // false for guest checkouts
  emailConsentGiven Boolean    @default(false) // Marketing opt-in
  loginAttempts     Int        @default(0) // For rate limiting
  lockedUntil       DateTime?  // For rate locking
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user    User     @relation(fields: [id], references: [id], onDelete: Cascade)
  orders  Order[]
  reviews Review[]
  wishlist Wishlist[]

  @@index([phone], map: "idx_customers_phone")
  @@index([role], map: "idx_customers_role")
}

/// Categories table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

/// Tags table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productTags ProductTag[]
}

/// Products table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Product {
  id             Int              @id @default(autoincrement())
  name           String
  slug           String           @unique
  description    String?
  price          Float            // Base price
  primaryImage   String?          // Primary image URL
  galleryImages  Json?            // Array of image URLs (native JSONB in PostgreSQL)
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean          @default(false)
  categoryId     Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  category     Category       @relation(fields: [categoryId], references: [id])
  variants     ProductVariant[]
  productTags  ProductTag[]
  reviews      Review[]
  wishlist     Wishlist[]

  @@index([categoryId], map: "idx_products_category_id")
  @@index([price], map: "idx_products_price")
}

/// Product Variants table
/// isOutOfStock maintained by DB trigger: set_is_out_of_stock
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductVariant {
  id            Int     @id @default(autoincrement())
  sku           String  @unique
  productId     Int
  variantType   String  // "size", "color", "material", "custom"
  variantValue  String  // "M", "Black", "Cotton", etc.
  price         Float?  // Override price (null = use product price)
  stockQuantity Int     @default(0)
  isOutOfStock  Boolean @default(false) // DB trigger: SET (stock_quantity <= 0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, variantType, variantValue], map: "unique_product_variant")
  @@index([productId], map: "idx_product_variants_product_id")
  @@index([stockQuantity], map: "idx_product_variants_stock")
}

/// Product Tags junction table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductTag {
  productId Int
  tagId     Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

/// Orders table
/// shipping_address stored as JSON with state field (Resolution #8)
/// NOTE: idx_orders_pending is a partial index (WHERE status = 'pending') — not
///       expressible in Prisma schema; managed directly in PostgreSQL.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Order {
  id              Int       @id @default(autoincrement())
  orderNumber     String    @unique
  customerId      String?
  status          String    @default("pending") // pending → confirmed → shipped → delivered / cancelled
  cartTotal       Float
  shippingAddress Json      // {"street","city","state","pincode"}
  consentGiven    Boolean   @default(false) // Marketing opt-in snapshot (Resolution #7)
  internalNotes   String?   // Admin notes
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  orderItems OrderItem[]

  @@index([customerId], map: "idx_orders_customer_id")
  @@index([status], map: "idx_orders_status")
  @@index([createdAt], map: "idx_orders_created_at")
  @@index([customerId, status], map: "idx_orders_customer_status")
  // idx_orders_pending: partial index (createdAt WHERE status = 'pending') — exists in DB, not in Prisma
}

/// Order Items table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderItem {
  id             Int            @id @default(autoincrement())
  orderId        Int
  variantId      Int
  quantity       Int
  unitPrice      Float   // Snapshot of price at order time
  variantSnapshot Json?   // Snapshot of variant details

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId], map: "idx_order_items_order_id")
  @@index([variantId], map: "idx_order_items_variant_id")
}

/// Reviews table
/// Purchase-validated: only delivered orders can review
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Review {
  id         Int      @id @default(autoincrement())
  productId  Int
  customerId String
  orderId    Int?
  rating     Int      // 1-5
  title      String?
  comment    String?
  photoUrl   String?
  status     String   @default("pending") // pending → approved/rejected/hidden
  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([productId, customerId], map: "unique_product_customer_review")
  @@index([productId], map: "idx_reviews_product_id")
  @@index([customerId], map: "idx_reviews_customer_id")
  @@index([status], map: "idx_reviews_status")
  @@index([productId, status], map: "idx_reviews_product_status")
  // idx_reviews_pending: partial index (createdAt WHERE status = 'pending') — exists in DB, not in Prisma
}

/// Wishlist table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Wishlist {
  customerId String
  productId  Int
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([customerId, productId])
}

/// FAQ table
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Faq {
  id           Int      @id @default(autoincrement())
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Homepage Content table — Singleton (only 1 row)
/// Uses native JSONB columns (PostgreSQL)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model HomepageContent {
  id                 Int      @id @default(1) // Fixed ID = 1, singleton
  heroBanner         Json?    // {"image_url","text","cta_text","cta_link"}
  featuredProductIds Json?    // Array of product IDs
  categoriesSection  Json?    // {"display_categories": [id,...]}
  whyChooseUs        Json?    // [{"icon","title","description"},...]
  /// JSON config: {"max_reviews_to_show": N}
  customerReviews    Json
  footer             Json?    // {"contact_text","social_links","copyright_text"}
  updatedAt          DateTime @updatedAt
}

/// Settings table — Key-Value store with native JSON values
/// No email config keys (V1 sends no automated emails)
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Setting {
  key   String @id
  value Json   // {"value": ...}
}

/// Order Track Attempts — Database-based rate limiting
/// Cleaned up via application logic
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderTrackAttempt {
  id          Int      @id @default(autoincrement())
  ipAddress   String
  attemptTime DateTime @default(now())
  expiresAt   DateTime

  @@index([ipAddress], map: "idx_order_track_ip")
  @@index([expiresAt], map: "idx_order_track_expires")
}